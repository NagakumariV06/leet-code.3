#include <vector>
#include <string>
#include <numeric>

using namespace std;

class Solution {
public:
    vector<string> fullJustify(vector<string>& words, int maxWidth) {
        vector<string> result;
        int i = 0;
        
        while (i < words.size()) {
            int j = i + 1;
            int lineLength = words[i].length();
            
            // Greedily find how many words fit in the current line
            while (j < words.size() && lineLength + words[j].length() + (j - i) <= maxWidth) {
                lineLength += words[j].length();
                j++;
            }
            
            string line = "";
            int numWords = j - i;
            int numGaps = numWords - 1;
            
            // Case 1: Last line or a line with only one word (Left-justified)
            if (j == words.size() || numWords == 1) {
                for (int k = i; k < j; k++) {
                    line += words[k];
                    if (k != j - 1) line += " ";
                }
                line += string(maxWidth - line.length(), ' ');
            } 
            // Case 2: Middle line with multiple words (Fully-justified)
            else {
                int totalSpaces = maxWidth - lineLength;
                int spacesPerGap = totalSpaces / numGaps;
                int extraSpaces = totalSpaces % numGaps;
                
                for (int k = i; k < j; k++) {
                    line += words[k];
                    if (k != j - 1) {
                        int spacesToAdd = spacesPerGap + (k - i < extraSpaces ? 1 : 0);
                        line += string(spacesToAdd, ' ');
                    }
                }
            }
            
            result.push_back(line);
            i = j; // Move to the next set of words
        }
        
        return result;
    }
};
