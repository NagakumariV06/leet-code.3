#include <vector>

class Solution {
public:
    int removeDuplicates(std::vector<int>& nums) {
        // If the array has 2 or fewer elements, it already meets the criteria
        if (nums.size() <= 2) {
            return nums.size();
        }

        // 'k' tracks the position where the next valid element should be placed
        int k = 2;

        // Iterate through the array starting from the third element
        for (int i = 2; i < nums.size(); i++) {
            // Compare the current element with the one two positions behind the write pointer
            // Since the array is sorted, this ensures we don't include more than two of the same value
            if (nums[i] != nums[k - 2]) {
                nums[k] = nums[i];
                k++;
            }
        }

        return k;
    }
};
