class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        // Edge cases: empty list, single node, or no rotations
        if (!head || !head->next || k == 0) return head;
        
        // Step 1: Compute the length of the linked list
        ListNode* tail = head;
        int length = 1;
        while (tail->next) {
            tail = tail->next;
            length++;
        }
        
        // Step 2: Normalize k
        k = k % length;
        if (k == 0) return head; // No rotation needed
        
        // Step 3: Connect tail to head to make it circular
        tail->next = head;
        
        // Step 4: Find the node that will become the new tail
        // The new tail is at (length - k - 1) steps from the start
        ListNode* new_tail = head;
        for (int i = 0; i < length - k - 1; ++i) {
            new_tail = new_tail->next;
        }
        
        // Step 5: Break the circle
        ListNode* new_head = new_tail->next;
        new_tail->next = nullptr;
        
        return new_head;
    }
};
