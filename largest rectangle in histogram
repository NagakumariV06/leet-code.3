#include <vector>
#include <stack>
#include <algorithm>

class Solution {
public:
    int largestRectangleArea(std::vector<int>& heights) {
        std::stack<int> st;
        int maxArea = 0;
        int n = heights.size();

        for (int i = 0; i <= n; i++) {
            // Use a height of 0 for an imaginary bar at the end to flush the stack
            int currentHeight = (i == n) ? 0 : heights[i];

            // While the current bar is shorter than the bar at the stack top
            while (!st.empty() && currentHeight < heights[st.top()]) {
                int h = heights[st.top()];
                st.pop();
                
                // Calculate width: 
                // If stack is empty, the bar 'h' was the shortest so far
                // Otherwise, the width is the distance between current index i 
                // and the new top of the stack minus 1.
                int w = st.empty() ? i : i - st.top() - 1;
                
                maxArea = std::max(maxArea, h * w);
            }
            st.push(i);
        }

        return maxArea;
    }
};
