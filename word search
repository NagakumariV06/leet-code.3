#include <vector>
#include <string>

using namespace std;

class Solution {
public:
    bool exist(vector<vector<char>>& board, string word) {
        int rows = board.size();
        int cols = board[0].size();
        
        for (int r = 0; r < rows; ++r) {
            for (int c = 0; c < cols; ++c) {
                if (dfs(board, word, 0, r, c)) return true;
            }
        }
        return false;
    }

private:
    bool dfs(vector<vector<char>>& board, const string& word, int index, int r, int c) {
        // 1. Base case: all characters found
        if (index == word.length()) return true;

        // 2. Out of bounds or character mismatch
        if (r < 0 || r >= board.size() || c < 0 || c >= board[0].size() || board[r][c] != word[index]) {
            return false;
        }

        // 3. Mark as visited
        char temp = board[r][c];
        board[r][c] = '#';

        // 4. Explore neighbors (Up, Down, Left, Right)
        bool found = dfs(board, word, index + 1, r + 1, c) ||
                     dfs(board, word, index + 1, r - 1, c) ||
                     dfs(board, word, index + 1, r, c + 1) ||
                     dfs(board, word, index + 1, r, c - 1);

        // 5. Backtrack: restore character
        board[r][c] = temp;

        return found;
    }
};
