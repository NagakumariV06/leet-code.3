#include <string>
#include <vector>
#include <climits>

using namespace std;

class Solution {
public:
    string minWindow(string s, string t) {
        if (s.length() < t.length()) return "";

        vector<int> map(128, 0);
        for (char c : t) map[c]++;

        int start = 0, end = 0, minStart = 0, minLen = INT_MAX;
        int counter = t.length(); // Total characters needed

        while (end < s.length()) {
            // If character at 'end' is needed, decrease counter
            if (map[s[end]] > 0) counter--;
            map[s[end]]--; // Mark character as used
            end++;

            // When window is valid (contains all chars of t)
            while (counter == 0) {
                if (end - start < minLen) {
                    minLen = end - start;
                    minStart = start;
                }

                // Try to shrink from the left
                map[s[start]]++;
                if (map[s[start]] > 0) counter++; // If it was a required char, increment counter
                start++;
            }
        }

        return minLen == INT_MAX ? "" : s.substr(minStart, minLen);
    }
};
