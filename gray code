#include <vector>

class Solution {
public:
    std::vector<int> grayCode(int n) {
        std::vector<int> result;
        // Total numbers in the sequence is 2^n
        int size = 1 << n; 
        result.reserve(size);
        
        for (int i = 0; i < size; i++) {
            // Apply the formula: i XOR (i shifted right by 1)
            result.push_back(i ^ (i >> 1));
        }
        
        return result;
    }
};
